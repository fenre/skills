# Splunk Knowledge Objects Worksheet
#
# Non-secret values only. The admin password comes from the project credentials file.

phase: render
app_name: search
object_kind: macro          # savedsearch | macro | lookup | eventtype | tag
name:

# savedsearch
search:
is_scheduled: false
cron_schedule:
dispatch_earliest_time:
dispatch_latest_time:
alert_type:
alert_condition:
actions:                    # e.g. email,webhook

# macro
definition:
args:
iseval: 0

# lookup
lookup_type: csv            # csv | kvstore
lookup_filename:            # for csv
collection:                 # for kvstore
fields_list:
csv_headers:
auto_lookup_sourcetype:
lookup_input_fields:
lookup_output_fields:

# eventtype / tag
eventtype_search:
tags:

# sharing / ownership (sharing=global requires --accept-global-sharing)
sharing: app
owner: nobody
read_roles:
write_roles:
