{
  "duo": {
    "title": "Cisco Duo",
    "input_type": "sbg_duo_input",
    "default_name": "Duo_Default",
    "required_fields": ["api_host"],
    "secret_fields": ["ikey", "skey", "proxy_password"],
    "required_secret_fields": ["ikey", "skey"],
    "defaults": {
      "index": "cisco_duo",
      "interval": "120",
      "sourcetype": "cisco:duo",
      "logging_level": "INFO"
    }
  },
  "secure_malware_analytics": {
    "title": "Cisco Secure Malware Analytics",
    "input_type": "cisco_sma_input",
    "default_name": "SMA_Default",
    "required_fields": ["api_host", "after"],
    "secret_fields": ["api_key", "proxy_password"],
    "required_secret_fields": ["api_key"],
    "defaults": {
      "index": "cisco_sma",
      "interval": "300",
      "sourcetype": "cisco:sma:submissions",
      "loglevel": "INFO"
    }
  },
  "xdr": {
    "title": "Cisco XDR",
    "input_type": "sbg_xdr_input",
    "default_name": "XDR_Default",
    "required_fields": ["region", "auth_method", "client_id", "xdr_import_time_range"],
    "secret_fields": ["refresh_token", "access_token", "password"],
    "conditional_required_secret_fields": [
      {"field": "auth_method", "value": "client_id", "secret_keys": ["refresh_token"]},
      {"field": "auth_method", "value": "access_token", "secret_keys": ["access_token"]},
      {"field": "auth_method", "value": "password", "secret_keys": ["password"]}
    ],
    "defaults": {
      "index": "cisco_xdr",
      "interval": "300",
      "sourcetype": "cisco:xdr:incidents"
    }
  },
