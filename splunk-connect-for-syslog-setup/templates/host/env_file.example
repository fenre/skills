# SC4S host env file
# Replace placeholder values locally. Keep the completed file out of git.

SC4S_DEST_SPLUNK_HEC_DEFAULT_URL={{HEC_BASE_URL}}
SC4S_DEST_SPLUNK_HEC_DEFAULT_TOKEN={{HEC_TOKEN}}
