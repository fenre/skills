# Cisco Intersight account intake template
#
# Copy this file to `template.local` in the same folder before entering real
# values. Keep the completed file local only.
#
# Fill in non-secret values only. Do not store the OAuth client secret in
# `template.local`.
#
# Create the secret temp file only when you are ready to run the configure script:
# printf '%s\n' '<intersight_client_secret>' > /tmp/intersight_client_secret && chmod 600 /tmp/intersight_client_secret
#
# Then pass:
#   --client-secret-file /tmp/intersight_client_secret
#
# Duplicate the section when you need more than one account.
#
# `stanza_name` is the account name that will appear in Splunk.
# Auto-populated fields such as MOID, account display name, and validity dates are
# intentionally omitted because the add-on fills them in after authentication.

[intersight_account]
stanza_name = INTERSIGHT_PROD
intersight_hostname = intersight.com
client_id =
# Set to 1 if you want the setup flow to enable the default input set.
create_default_inputs = 1
