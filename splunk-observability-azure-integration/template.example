# Splunk Observability Cloud — Azure Integration spec.
#
# Copy this file locally (e.g. template.local.yaml) and fill in non-secret values.
# The skill reads the Splunk O11y token from --token-file (chmod 600).
# Azure appId and secretKey are read from --app-id-file and --secret-file (chmod 600).
# NEVER put any secret value in this file.

api_version: splunk-observability-azure-integration/v1

# Splunk Observability Cloud realm.
# Supported: us0 us1 us2 us3 eu0 eu1 eu2 au0 jp0 sg0
realm: us1

# Human-readable name for this integration in Splunk O11y.
integration_name: production-azure-tenant-1

# ── Authentication ──────────────────────────────────────────────────────────
authentication:
  # Azure AD Directory (tenant) ID.
  tenant_id: "00000000-0000-0000-0000-000000000000"

  # Azure AD application (client) ID. Deliver via --app-id-file (chmod 600).
  # Do NOT put the value here.
  app_id_file: ""

  # Azure AD client secret. Deliver via --secret-file (chmod 600).
  # Do NOT put the value here.
  secret_file: ""

# ── Azure environment ────────────────────────────────────────────────────────
# AZURE                  — Commercial Azure (default)
# AZURE_US_GOVERNMENT    — Azure US Government (USGov); must also use a GovCloud realm
azure_environment: AZURE

# ── Subscriptions ────────────────────────────────────────────────────────────
# List of Azure subscription IDs to monitor.
subscriptions:
  - "00000000-0000-0000-0000-000000000000"

# ── Connection ────────────────────────────────────────────────────────────────
connection:
  mode: polling                # polling (default) | terraform_only
  poll_rate_seconds: 300       # 60..600 (wire pollRate is milliseconds; skill converts)
  use_batch_api: true          # Use Azure Monitor Metrics Batch API (recommended)
  import_azure_monitor: true   # true = import metrics; false = metadata only
  sync_guest_os_namespaces: false  # Sync non-standard guest-OS metric namespaces

# ── Services ──────────────────────────────────────────────────────────────────
# See references/services-enum.json for the full ~80-entry enum.
# Set mode to all_built_in to subscribe to all built-in services.
services:
  mode: explicit               # all_built_in | explicit
  explicit:
    - microsoft.compute/virtualmachines
    - microsoft.compute/virtualmachinescalesets
    - microsoft.storage/storageaccounts
    - microsoft.containerservice/managedclusters
    - microsoft.web/sites
    - microsoft.sql/servers/databases
    - microsoft.eventhub/namespaces
    - microsoft.servicebus/namespaces
    - microsoft.network/loadbalancers
    - microsoft.network/applicationgateways
  # Use additional_services for namespaces not in the built-in enum.
  additional_services: []
  # Per-service custom namespaces: [{service: "microsoft.compute/virtualmachines", namespaces: ["CustomNS/Metrics"]}]
  custom_namespaces_per_service: []

# ── Resource filter rules ─────────────────────────────────────────────────────
# Filter resources by tag. Example:
# resource_filter_rules:
#   - filter_source: "filter('azure_tag_environment','production') and filter('azure_tag_team','platform')"
resource_filter_rules: []

# ── Named token ───────────────────────────────────────────────────────────────
# Splunk O11y org token name for this integration's data.
# WARNING: Changing named_token destroys and re-creates the integration (ForceNew in Terraform).
named_token: ""

# ── Terraform provider ────────────────────────────────────────────────────────
terraform_provider:
  source: splunk-terraform/signalfx
  version: "~> 9.0"

# ── Azure CLI render ──────────────────────────────────────────────────────────
# Emit azure-cli/ scripts for SP creation and role assignment.
azure_cli_render: true

# ── Bicep template ────────────────────────────────────────────────────────────
# Emit bicep/role-assignment.bicep for declarative role assignment.
bicep_render: false

# ── Multi-subscription ────────────────────────────────────────────────────────
multi_subscription:
  enabled: false
  # Set management_group_id to scope role assignment to a management group.
  management_group_id: ""

# ── Cross-skill handoffs ──────────────────────────────────────────────────────
# Set true to emit handoff driver scripts.
handoffs:
  splunk_ta_microsoft_cloud_services: false  # Splunkbase 3110 — Azure log ingestion
  microsoft_azure_app: false                 # Splunkbase 4882 — Azure dashboards for Splunk Platform
  aks_otel_collector: false                  # splunk-observability-otel-collector-setup (AKS host telemetry)
  dashboards: false                          # splunk-observability-dashboard-builder
  detectors: false                           # splunk-observability-native-ops
