# Cisco ThousandEyes account intake template
#
# Copy this file to `template.local` in the same folder before entering real
# values. Keep the completed file local only.
#
# This worksheet intentionally collects only non-secret values.
# No temp key files are required for account authorization because the
# ThousandEyes app uses OAuth 2.0 Device Code flow.
#
# Browser-based authorization is completed later by the account owner or a
# delegated admin, so generated OAuth fields are intentionally omitted here.
# HEC settings, indexes, and input enablement are handled separately in the
# setup workflow rather than in this account worksheet.

[thousandeyes_account]
# Use the ThousandEyes user email as the stanza name.
stanza_name = user@example.com

# Generated by the app during authorization and intentionally not requested here:
# access_token
# refresh_token
# device_code
# user_code
# verification_url
