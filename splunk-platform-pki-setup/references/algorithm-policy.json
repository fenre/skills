{
  "_comment": "Machine-readable companion to algorithm-presets.md. Consumed by render_assets.py and preflight.sh. The same cipher_suite + ecdh_curves constants appear in the splunk-enterprise-public-exposure-hardening renderer so the two skills agree on the on-the-wire crypto.",
  "tls_version_floor": "tls1.2",
  "tls_version_supported": ["tls1.2"],
  "tls_version_forbidden": ["ssl3", "tls1.0", "tls1.1"],
  "tls_version_not_yet_supported": ["tls1.3"],
  "presets": {
    "splunk-modern": {
      "description": "Splunk's documented modern cipher set per https://docs.splunk.com/Documentation/Splunk/latest/Security/AboutTLSencryptionandciphersuites",
      "ssl_versions": "tls1.2",
      "ssl_versions_for_client": "tls1.2",
      "cipher_suite": "ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-SHA384:ECDHE-RSA-AES256-SHA384:ECDHE-ECDSA-AES128-SHA256:ECDHE-RSA-AES128-SHA256",
      "ecdh_curves": "prime256v1, secp384r1, secp521r1",
      "allowed_key_algorithms": ["rsa-2048", "rsa-3072", "rsa-4096", "ecdsa-p256", "ecdsa-p384", "ecdsa-p521"],
      "allowed_signature_algorithms": ["RSA-SHA256", "RSA-SHA384", "RSA-SHA512", "ECDSA-SHA256", "ECDSA-SHA384", "ECDSA-SHA512"],
      "minimum_rsa_bits": 2048,
      "minimum_ecdsa_curve": "secp256r1",
      "ldap_tls_protocol_min": "3.3",
      "ldap_tls_cipher_suite": "ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256"
    },
    "fips-140-3": {
      "description": "NIST-approved AEAD only per https://help.splunk.com/en/splunk-enterprise/administer/manage-users-and-security/10.2/establish-and-maintain-compliance-with-fips-and-common-criteria-in-splunk-enterprise/secure-splunk-enterprise-with-fips. No CBC, no SHA-1, no anonymous DH, no RSA-1024.",
      "ssl_versions": "tls1.2",
      "ssl_versions_for_client": "tls1.2",
      "cipher_suite": "ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256",
      "ecdh_curves": "prime256v1, secp384r1, secp521r1",
      "allowed_key_algorithms": ["rsa-2048", "rsa-3072", "rsa-4096", "ecdsa-p256", "ecdsa-p384", "ecdsa-p521"],
      "allowed_signature_algorithms": ["RSA-SHA256", "RSA-SHA384", "RSA-SHA512", "ECDSA-SHA256", "ECDSA-SHA384", "ECDSA-SHA512"],
      "minimum_rsa_bits": 2048,
      "minimum_ecdsa_curve": "secp256r1",
      "forbidden_signature_algorithms": ["RSA-SHA1", "MD5", "DSA"],
      "forbidden_cipher_substrings": ["NULL", "EXPORT", "RC4", "DES", "3DES", "MD5", "anon", "CBC", "SHA1"],
      "ldap_tls_protocol_min": "3.3",
      "ldap_tls_cipher_suite": "ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256",
      "splunk_launch_conf": {
        "SPLUNK_FIPS_VERSION": "140-3"
      }
    },
    "stig": {
      "description": "DISA STIG-aligned subset of fips-140-3 per splunk-enterprise-public-exposure-hardening/references/disa-stig-cross-reference.md. Refuses RSA-2048 and ECDSA P-256 leaves; requires RSA-3072+ or ECDSA P-384+.",
      "ssl_versions": "tls1.2",
      "ssl_versions_for_client": "tls1.2",
      "cipher_suite": "ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256",
      "ecdh_curves": "secp384r1, secp521r1",
      "allowed_key_algorithms": ["rsa-3072", "rsa-4096", "ecdsa-p384", "ecdsa-p521"],
      "allowed_signature_algorithms": ["RSA-SHA384", "RSA-SHA512", "ECDSA-SHA384", "ECDSA-SHA512"],
      "minimum_rsa_bits": 3072,
      "minimum_ecdsa_curve": "secp384r1",
      "forbidden_signature_algorithms": ["RSA-SHA1", "RSA-SHA256", "MD5", "DSA"],
      "forbidden_cipher_substrings": ["NULL", "EXPORT", "RC4", "DES", "3DES", "MD5", "anon", "CBC", "SHA1", "SHA256"],
      "ldap_tls_protocol_min": "3.3",
      "ldap_tls_cipher_suite": "ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384"
    }
  },
  "validity_days": {
    "root_ca_default": 3650,
    "intermediate_ca_default": 1825,
    "leaf_default_private": 825,
    "leaf_cap_private": 825,
    "leaf_default_public": 397,
    "leaf_warn_above_public": 397,
    "leaf_warn_acme_floor": 90
