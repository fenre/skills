# Splunk Dashboard Studio Worksheet
#
# Non-secret values only. The admin password comes from the project credentials file.

phase: render
app_name: search

dashboard_name: net_overview
title: Network Overview
description:
theme: light                # light | dark
layout: grid                # grid | absolute | freeform

# Build from a search (or use definition_file for a full JSON definition)
search: index=netfw | stats count by action
viz_type: splunk.column     # splunk.table | splunk.singlevalue | splunk.line | ...
datasource_name: Search_1
definition_file:

# Sharing / ownership
owner: nobody
sharing: app                # user | app | global

# Overwriting an existing dashboard requires --accept-overwrite
